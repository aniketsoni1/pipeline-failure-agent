{
  "name": "pipeline-failure-agent",
  "version": "0.1.2",
  "description": "Intelligent, deterministic-first troubleshooting agent for failed data pipelines, jobs, queries and workflows. Shared core powering a CLI and a VS Code extension.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=18.18"
  },
  "bin": {
    "pipeline-agent": "dist/cli/index.cjs"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "node scripts/build-cli.mjs",
    "build:cli": "node scripts/build-cli.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write .",
    "cli": "tsx apps/cli/src/index.ts",
    "demo": "tsx apps/cli/src/index.ts investigate samples/python-column-rename/logs/run.log --format markdown",
    "prepublishOnly": "npm run build:cli"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "picocolors": "^1.1.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "@types/node": "^20.14.0",
    "esbuild": "^0.24.0",
    "eslint": "^9.13.0",
    "tsx": "^4.19.2",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.11.0",
    "vitest": "^2.1.8"
  }
}
