{
  "name": "pipeline-failure-agent",
  "version": "0.1.0",
  "private": true,
  "description": "Intelligent, deterministic-first troubleshooting agent for failed data pipelines, jobs, queries and workflows. Shared core powering a CLI and a VS Code extension.",
  "license": "Apache-2.0",
  "type": "module",
  "engines": {
    "node": ">=18.18"
  },
  "bin": {
    "pipeline-agent": "apps/cli/bin/pipeline-agent.mjs"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint . --ext .ts",
    "format": "prettier --write .",
    "cli": "tsx apps/cli/src/index.ts",
    "demo": "tsx apps/cli/src/index.ts investigate samples/python-column-rename/logs/run.log --format markdown"
  },
  "dependencies": {
    "commander": "^12.1.0",
    "picocolors": "^1.1.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "tsx": "^4.19.2",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  }
}
